#!/bin/bash
set -euo pipefail
shopt -s dotglob

# Script for symlinking config files

DOTFILES="$HOME/dotfiles"
CONFIG="$HOME/.config"
IS_LINUX=$([ "$(uname -s)" = "Linux" ] && echo 1 || echo 0)

link_dir_contents() {
  local src_base="$1"
  local dest_base="$2"
  [ -d "$src_base" ] || return

  for path in "$src_base"/*; do
    [ -e "$path" ] || continue
    local name
    name="$(basename "$path")"
    ./create_symlink "$path" "$dest_base/$name"
  done
}

# Linux

if [[ "$IS_LINUX" -eq 1 ]]; then
  LINUX_PROGRAMS="$DOTFILES/programs/linux"
  link_dir_contents "$LINUX_PROGRAMS/config" "$CONFIG"
  link_dir_contents "$LINUX_PROGRAMS/home" "$HOME"
fi

# Mac

if [[ "$IS_LINUX" -eq 0 ]]; then
  MAC_PROGRAMS="$DOTFILES/programs/mac"
  link_dir_contents "$MAC_PROGRAMS" "$CONFIG"
fi

# Shared

SHARED_PROGRAMS="$DOTFILES/programs/shared"
link_dir_contents "$SHARED_PROGRAMS" "$CONFIG"
./create_symlink "$SHARED_PROGRAMS/zsh/.zshrc" "$HOME/.zshrc"

# Scripts

link_dir_contents "$DOTFILES/scripts/general" "$HOME/.local/bin"


# Exit
printf "\n%s\n" "OK"
exit;

